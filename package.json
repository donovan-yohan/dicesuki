{
  "name": "dicesuki",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,dice -c blue,yellow \"vite\" \"node scripts/watch-dice-manifest.js\"",
    "dev:local-room": "concurrently -n server,vite,dice -c green,blue,yellow \"npm run dev:server\" \"vite\" \"node scripts/watch-dice-manifest.js\"",
    "dev:server": "cd server && PORT=8080 ~/.cargo/bin/cargo run",
    "dev:vite": "vite",
    "build": "node scripts/generate-dice-manifest.js && tsc && vite build",
    "capture:imagegen-d20": "node scripts/imagegen-uv/capture-d20-proof.mjs",
    "capture:theme-workshop": "node scripts/imagegen-uv/capture-theme-workshop.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e:local-room": "PLAYWRIGHT_TEST_PORT=${PLAYWRIGHT_TEST_PORT:-18181} DICESUKI_ROOM_TEST_PORT=${DICESUKI_ROOM_TEST_PORT:-18180} VITE_LOCAL_ROOM_SERVER_URL=${VITE_LOCAL_ROOM_SERVER_URL:-ws://127.0.0.1:${DICESUKI_ROOM_TEST_PORT:-18180}} VITE_LOCAL_ROOM_SERVER_HTTP_URL=${VITE_LOCAL_ROOM_SERVER_HTTP_URL:-http://127.0.0.1:${DICESUKI_ROOM_TEST_PORT:-18180}} playwright test e2e/local-loopback-room.spec.ts",
    "test:coverage": "vitest --coverage",
    "generate-dice-manifest": "node scripts/generate-dice-manifest.js",
    "generate:continuous-uv": "node scripts/imagegen-uv/continuous-d6.mjs",
    "generate:d20-imagegen-template": "node scripts/imagegen-uv/d20-mesh-template.mjs",
    "generate:theme-workshop": "node scripts/imagegen-uv/generate-theme-workshop.mjs",
    "register:theme-atlases": "node scripts/imagegen-uv/register-theme-atlases.mjs",
    "generate:theme-normal-maps": "node scripts/imagegen-uv/derive-theme-normal-maps.mjs",
    "generate:theme-dice-sets": "node scripts/production-dice-fixtures/generate-themed-imagegen-sets.mjs && node scripts/generate-dice-manifest.js",
    "generate:imagegen-d20-normal": "node scripts/imagegen-uv/derive-normal-map.mjs",
    "generate:imagegen-uv": "node scripts/imagegen-uv/generate.mjs && node scripts/imagegen-uv/d20-mesh-template.mjs",
    "generate:production-fixtures": "npm run generate:imagegen-d20-normal && node scripts/production-dice-fixtures/generate.mjs && node scripts/generate-dice-manifest.js",
    "test:production-fixtures": "vitest run src/lib/productionDiceFixtures.test.ts",
    "test:imagegen-uv": "node scripts/imagegen-uv/validate.mjs && node scripts/imagegen-uv/validate-d20-mesh-template.mjs && node scripts/imagegen-uv/validate-themed-dice-contract.mjs && node scripts/imagegen-uv/validate-theme-atlas-registration.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "detect-gpu": "^5.0.0",
    "framer-motion": "^12.23.24",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "three": "^0.162.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.162.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.0.8",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^27.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^4.0.8"
  }
}
