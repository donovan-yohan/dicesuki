{
  "name": "dicesuki",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,dice -c blue,yellow \"vite\" \"node scripts/watch-dice-manifest.js\"",
    "dev:server": "cd server && PORT=8080 ~/.cargo/bin/cargo run",
    "dev:vite": "vite",
    "build:wasm-room": "bash scripts/build-wasm-room.sh",
    "generate:brand-icons": "node scripts/generate-brand-icons.mjs",
    "build": "node scripts/generate-collectible-catalog.js --check && node scripts/generate-economy-disclosures.js --check && node scripts/economy-simulator.js --check && node scripts/validate-production-economy.js && node scripts/runtime-dice-assets/validate.mjs && node scripts/generate-dice-manifest.js --check && tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e:solo": "PLAYWRIGHT_TEST_PORT=${PLAYWRIGHT_TEST_PORT:-18181} playwright test e2e/solo-wasm-room.spec.ts",
    "test:e2e:runtime-dice": "PLAYWRIGHT_TEST_PORT=${PLAYWRIGHT_TEST_PORT:-18182} playwright test e2e/cozy-forest-runtime.spec.ts",
    "test:coverage": "vitest --coverage",
    "generate:collectible-catalog": "node scripts/generate-collectible-catalog.js",
    "check:collectible-catalog": "node scripts/generate-collectible-catalog.js --check",
    "check:immutable-catalog-history": "node scripts/check-immutable-catalog-history.js",
    "generate:economy-disclosures": "node scripts/generate-economy-disclosures.js --write-new",
    "check:economy-disclosures": "node scripts/generate-economy-disclosures.js --check",
    "generate:economy-simulations": "node scripts/economy-simulator.js --write-new",
    "check:economy-simulations": "node scripts/economy-simulator.js --check",
    "check:production-economy": "node scripts/validate-production-economy.js",
    "test:db:wallet-ledger": "node scripts/test-wallet-ledger-postgres.mjs",
    "check:immutable-economy-history": "node scripts/check-immutable-economy-history.js",
    "prepare:collectible-edition": "node scripts/generate-collectible-catalog.js --prepare-edition",
    "generate:imagegen-uv": "node scripts/imagegen-uv/generate-authoring-kit.mjs",
    "generate:imagegen-uv:raster": "node scripts/imagegen-uv/generate-authoring-kit.mjs --rasterize",
    "validate:imagegen-uv": "node scripts/imagegen-uv/generate-authoring-kit.mjs --validate-only",
    "check:imagegen-authoring-boundary": "node scripts/imagegen-uv/check-authoring-boundary.mjs",
    "check:immutable-imagegen-history": "node scripts/imagegen-uv/check-canonical-history.mjs",
    "test:imagegen-uv": "node --test scripts/imagegen-uv/imagegen-authoring.node-test.mjs && npm run check:imagegen-authoring-boundary",
    "build:runtime-dice-assets": "node scripts/runtime-dice-assets/optimize.mjs",
    "check:runtime-dice-assets": "node scripts/runtime-dice-assets/validate.mjs",
    "test:runtime-dice-assets": "node --test scripts/runtime-dice-assets/runtime-dice-assets.node-test.mjs",
    "generate-dice-manifest": "node scripts/generate-dice-manifest.js --write",
    "check:dice-manifest": "node scripts/generate-dice-manifest.js --check"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/supabase-js": "^2.110.2",
    "detect-gpu": "^5.0.0",
    "framer-motion": "^12.23.24",
    "qrcode-generator": "^1.4.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "three": "^0.162.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "4.4.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.162.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "4.0.8",
    "@vitest/ui": "^4.0.8",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^27.1.0",
    "postcss": "^8.4.35",
    "sharp": "0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.8"
  }
}
