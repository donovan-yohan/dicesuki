# Daisu environment configuration — copy to `.env.local` and fill in.
# Every value is OPTIONAL: with none set, the app runs in guest mode exactly
# as it does today (no accounts, no crashes, no console noise).

# --- Multiplayer / room servers -------------------------------------------
# Public multiplayer room server (WebSocket + HTTP).
# VITE_MULTIPLAYER_SERVER_URL=ws://localhost:8080
# VITE_MULTIPLAYER_SERVER_HTTP_URL=http://localhost:8080

# Local loopback solo room server (separate from the public server on purpose).
# VITE_LOCAL_ROOM_SERVER_URL=ws://127.0.0.1:8080
# VITE_LOCAL_ROOM_SERVER_HTTP_URL=http://127.0.0.1:8080

# --- Supabase accounts & profiles (issue #81, ADR 006) --------------------
# Enables Discord OAuth sign-in and cloud profiles. Leave BOTH unset to keep
# the app in guest-only mode. The anon key is public-safe (protected by RLS);
# never put the service-role key or JWT secret here.
# Project id `nksxdfcjabgbxeefwkdc` is public-safe.
# VITE_SUPABASE_URL=https://nksxdfcjabgbxeefwkdc.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-sb_publishable-key
# VITE_SUPABASE_ANON_KEY=legacy-public-anon-key

# --- Discord room bot (issue #84, SERVER-side only) -----------------------
# Set on the ROOM SERVER (server/), not the frontend. When all three are
# present the server advertises each public room as an auto-updating embed
# (name, theme, player count) with a Join button in the configured channel.
# Leave any unset to keep the bot OFF (server runs unchanged). The bot token is
# a SECRET — never commit it; supply via env/secret storage. See
# docs/guides/discord.md for the one-time Discord app/bot setup checklist.
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_CHANNEL_ID=123456789012345678
# APP_BASE_URL=https://your-frontend-domain   # used to build /room/<id> join links
